-- Roblox的ViewportPointToRay在某些情况下会偏移，depth补偿一下
function Math.ScreenToWorld(screenPos, depth, camera)
	camera = camera or workspace.CurrentCamera
	local ray = camera:ViewportPointToRay(screenPos.X, screenPos.Y)
	return ray.Origin + ray.Direction * depth
end

function Math.IsOnScreen(worldPos, camera)
	camera = camera or workspace.CurrentCamera
	local _, _, onScreen = camera:WorldToViewportPoint(worldPos)
	return onScreen
end

function Math.GetFrustumPlanes(camera)
	camera = camera or workspace.CurrentCamera
	local cf = camera.CFrame
	local fov = camera.FieldOfView * DEG_TO_RAD / 2
	local viewport = camera.ViewportSize
	local aspect = viewport.X / viewport.Y
	local near = camera.NearPlaneZ
	local far = camera.FarPlaneZ

	local tanY = math.tan(fov)
	local tanX = tanY * aspect
	local forward = cf.LookVector
	local right = cf.RightVector
	local up = cf.UpVector
	local pos = cf.Position

	local nearCenter = pos + forward * near
	local farCenter = pos + forward * far
	local nearH = tanY * near
	local nearW = tanX * near

	return {
		{ Point = nearCenter, Normal = forward },
		{ Point = farCenter, Normal = -forward },
		{ Point = pos, Normal = Math.Normalize(nearCenter - right * nearW - pos) },
		{ Point = pos, Normal = Math.Normalize(nearCenter + right * nearW - pos) },
		{ Point = pos, Normal = Math.Normalize(nearCenter - up * nearH - pos) },
		{ Point = pos, Normal = Math.Normalize(nearCenter + up * nearH - pos) },
	}
end

function Math.IsInFrustum(worldPos, radius, camera)
	camera = camera or workspace.CurrentCamera
	local planes = Math.GetFrustumPlanes(camera)
	radius = radius or 0
	for _, plane in ipairs(planes) do
		if Math.Dot(worldPos - plane.Point, plane.Normal) < -radius then
			return false
		end
	end
	return true
end

function Math.CirclePoint(center, radius, angle)
	return center + Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
end

function Math.SpiralPoint(center, radius, angle, heightPerRadian)
	return center + Vector3.new(
		math.cos(angle) * radius,
		angle * (heightPerRadian or 1),
		math.sin(angle) * radius
	)
end

function Math.BezierPoint(p0, p1, p2, p3, t)
	local u = 1 - t
	return u * u * u * p0 + 3 * u * u * t * p1 + 3 * u * t * t * p2 + t * t * t * p3
end

function Math.BezierTangent(p0, p1, p2, p3, t)
	local u = 1 - t
	return Math.Normalize(3 * u * u * (p1 - p0) + 6 * u * t * (p2 - p1) + 3 * t * t * (p3 - p2))
end

function Math.CatmullRomPoint(p0, p1, p2, p3, t)
	local tt = t * t
	local ttt = tt * t
	return 0.5 * ((2 * p1) + (-p0 + p2) * t + (2 * p0 - 5 * p1 + 4 * p2 - p3) * tt + (-p0 + 3 * p1 - 3 * p2 + p3) * ttt)
end

function Math.RigidBody(mass, position, velocity, gravity)
	mass = mass or 1
	position = position or Vector3.zero
	velocity = velocity or Vector3.zero
	gravity = gravity or Vector3.new(0, -workspace.Gravity, 0)

	local body = {
		Mass = mass,
		Position = position,
		Velocity = velocity,
		Acceleration = Vector3.zero,
		AngularVelocity = Vector3.zero,
		Rotation = CFrame.new(position),
		Forces = {},
		Torques = {},
		DragCoefficient = 0,
		AngularDrag = 0.1,
		UseGravity = true,
		Gravity = gravity,
		IsKinematic = false,
	}

	function body:AddForce(force, atPosition)
		table.insert(self.Forces, force)
		if atPosition then
			local lever = atPosition - self.Position
			table.insert(self.Torques, Math.Cross(lever, force))
		end
	end

	function body:AddImpulse(impulse, atPosition)
		self.Velocity = self.Velocity + impulse / self.Mass
		if atPosition then
			local lever = atPosition - self.Position
			self.AngularVelocity = self.AngularVelocity + Math.Cross(lever, impulse) / self.Mass
		end
	end

	function body:Update(dt)
		if self.IsKinematic then return end

		local totalForce = Vector3.zero
		if self.UseGravity then
			totalForce = totalForce + self.Gravity * self.Mass
		end

		local forces = self.Forces
		local torques = self.Torques
		self.Forces = {}
		self.Torques = {}
		for _, force in ipairs(forces) do
			totalForce = totalForce + force
		end
		totalForce = totalForce - self.Velocity * self.DragCoefficient

		local totalTorque = Vector3.zero
		for _, torque in ipairs(torques) do
			totalTorque = totalTorque + torque
		end
		totalTorque = totalTorque - self.AngularVelocity * self.AngularDrag

		self.Acceleration = totalForce / self.Mass
		self.Velocity = self.Velocity + self.Acceleration * dt
		self.Position = self.Position + self.Velocity * dt

		local avMag = self.AngularVelocity.Magnitude
		if avMag > EPSILON then
			local angle = avMag * dt
			local axis = self.AngularVelocity / avMag
			self.Rotation = self.Rotation * CFrame.fromAxisAngle(axis, angle)
		end
		self.AngularVelocity = self.AngularVelocity + totalTorque * dt
	end

	function body:Destroy()
		self.Forces = nil
		self.Torques = nil
	end

	return body
end

function Math.PositionRotation(cf)
	local px, py, pz = cf.X, cf.Y, cf.Z
	local rx, ry, rz = cf:ToEulerAnglesXYZ()
	return Vector3.new(px, py, pz), Vector3.new(rx, ry, rz)
end

function Math.FromPositionRotation(position, rotation)
	return CFrame.new(position) * CFrame.fromEulerAnglesXYZ(rotation.X, rotation.Y, rotation.Z)
end

function Math.RotateAroundPivot(cf, pivot, rotation)
	if rotation == nil then return cf end
	return pivot * rotation * pivot:Inverse() * cf
end

function Math.QuadBezier(p0, p1, p2, t)
	t = t or 0
	local u = 1 - t
	return u * u * p0 + 2 * u * t * p1 + t * t * p2
end

-- 旧版用的是 math.atan2(math.sin(b-a), math.cos(b-a))，效果一样但慢
-- local function angleDistance_old(a, b) return math.atan2(math.sin(b-a), math.cos(b-a)) end
function Math.AngleDistance(a, b)
	local diff = (b - a) % (2 * PI)
	if diff > PI then diff = diff - 2 * PI end
	return diff
end

-- 高中数学，余弦定理

function Math.LawOfCosines(a, b, c)
	local cosC = (a * a + b * b - c * c) / (2 * a * b)
	cosC = Math.Clamp(cosC, -1, 1)
	return math.acos(cosC)
end

-- 我知道下面这三个函数可以合并，但分开更好懂

function Math.Round(value, multiple)
	multiple = multiple or 1
	return math.floor(value / multiple + 0.5) * multiple
end

function Math.RoundUp(value, multiple)
	multiple = multiple or 1
	return math.ceil(value / multiple) * multiple
end

function Math.RoundDown(value, multiple)
	multiple = multiple or 1
	return math.floor(value / multiple) * multiple
end

return Math
