function Math.GetMaterialProperty(material)
	if typeof(material) == "EnumItem" then
		return Math.MaterialProperties[material] or Math.MaterialProperties[DEFAULT_MATERIAL]
	end
	return Math.MaterialProperties[DEFAULT_MATERIAL]
end

function Math.ProcessHit(bullet, hitPosition, hitNormal, hitMaterial, config)
	config = config or {}
	local maxPenetrations = config.MaxPenetrations or 2
	local maxRicochets = config.MaxRicochets or 3
	local minRicochetAngle = config.MinRicochetAngle or 20

	local matProp = Math.GetMaterialProperty(hitMaterial)
	local hitAngle = math.deg(math.asin(Math.Clamp(Math.Dot(Math.Normalize(bullet.Velocity), hitNormal), -1, 1)))

	if matProp.Penetrable and bullet.Penetrations < maxPenetrations then
		local thickness = matProp.MaxPenetrationDepth or 1
		local speedRetention = matProp.SpeedRetention ^ (thickness * 2)
		local newSpeed = bullet.Speed * speedRetention
		local newDamage = bullet.Damage * matProp.DamageRetention

		bullet.Penetrations = bullet.Penetrations + 1
		bullet.Velocity = Math.Normalize(bullet.Velocity) * newSpeed
		bullet.Speed = newSpeed
		bullet.Damage = newDamage

		local penetrationOffset = math.max(0.05, math.min(bullet.Speed * (config.TimeStep or 0.02) * 0.5, 0.5))
		bullet.Position = hitPosition + Math.Normalize(bullet.Velocity) * penetrationOffset

		bullet.LastHit = {
			Type = "Penetration",
			Position = hitPosition,
			Normal = hitNormal,
			Material = hitMaterial,
			ExitVelocity = bullet.Velocity,
			ExitDamage = bullet.Damage,
		}

		table.insert(bullet.Trail, bullet.LastHit)

		if newSpeed < 50 then
			bullet.Alive = false
		end

		return bullet, "Penetration"
	end

	local ricochetAngle = math.abs(hitAngle)
	if ricochetAngle > minRicochetAngle
		and bullet.Ricochets < maxRicochets
		and bullet._rng:NextNumber() < (matProp.RicochetChance or 0) then

		local reflectDir = Math.Reflect(Math.Normalize(bullet.Velocity), hitNormal)
		local randomness = matProp.RicochetAngleRandomness or 5
		reflectDir = Math.RandomPointInCone(reflectDir, math.rad(randomness), bullet._rng)

		local newSpeed = bullet.Speed * matProp.SpeedRetention
		local newDamage = bullet.Damage * matProp.DamageRetention

		bullet.Ricochets = bullet.Ricochets + 1
		bullet.Velocity = reflectDir * newSpeed
		bullet.Speed = newSpeed
		bullet.Damage = newDamage
		bullet.Position = hitPosition + hitNormal * 0.05

		bullet.LastHit = {
			Type = "Ricochet",
			Position = hitPosition,
			Normal = hitNormal,
			Material = hitMaterial,
			Angle = ricochetAngle,
			ReflectDirection = reflectDir,
			ExitVelocity = bullet.Velocity,
			ExitDamage = bullet.Damage,
			Spark = matProp.SparkOnRicochet or false,
		}

		table.insert(bullet.Trail, bullet.LastHit)

		if newSpeed < 80 then
			bullet.Alive = false
		end

		return bullet, "Ricochet"
	end

	bullet.Alive = false
	bullet.Position = hitPosition
	bullet.Velocity = Vector3.zero
	bullet.Speed = 0

	bullet.LastHit = {
		Type = "Stop",
		Position = hitPosition,
		Normal = hitNormal,
		Material = hitMaterial,
		FinalDamage = bullet.Damage,
	}

	table.insert(bullet.Trail, bullet.LastHit)

	return bullet, "Stop"
end

function Math.SimulateBullet(origin, direction, speed, damage, gravity, config)
	gravity = gravity or workspace.Gravity
	config = config or {}
	local timeStep = config.TimeStep or 0.02
	local maxTime = config.MaxTime or 20
	local raycastParams = config.RaycastParams

	local rng = config.RNG or globalRNG

	local bullet = Math.Bullet(origin, direction * speed, damage, rng)
	local vel = bullet.Velocity
	local pos = bullet.Position
	local t = 0
	local g = Vector3.new(0, -gravity, 0)
	local drag = config.Drag or 0
	local wind = config.Wind or Vector3.zero

	local events = {}

	while bullet.Alive and t < maxTime and pos.Y > -2000 do
		local nextPos = pos + vel * timeStep + 0.5 * g * timeStep * timeStep
		local stepDir = nextPos - pos
		local stepDist = stepDir.Magnitude

		if stepDist > EPSILON then
			local result
			if raycastParams then
				result = workspace:Raycast(pos, stepDir.Unit * stepDist, raycastParams)
			end

			if result then
				local hitPos = result.Position
				local hitNormal = result.Normal
				local hitMaterial = result.Material

				bullet.Position = hitPos
				bullet.Velocity = vel
				bullet.Speed = vel.Magnitude

				local _, hitType = Math.ProcessHit(bullet, hitPos, hitNormal, hitMaterial, config)
				table.insert(events, {
					Time = t,
					Position = hitPos,
					Normal = hitNormal,
					Material = hitMaterial,
					Type = hitType,
					Damage = bullet.Damage,
					Penetrations = bullet.Penetrations,
					Ricochets = bullet.Ricochets,
					Instance = result.Instance,
				})

				if not bullet.Alive then break end

				vel = bullet.Velocity
				pos = bullet.Position
			else
				pos = nextPos
			end
		else
			pos = nextPos
		end

		local acceleration = g + wind - drag * vel
		vel = vel + acceleration * timeStep
		t = t + timeStep
	end

	return events, bullet
end

function Math.GenerateBulletTrail(events, origin)
	if not events or #events == 0 then
		return {}
	end
	local points = { origin }
	for i = 1, #events do
		points[#points + 1] = events[i].Position
		if events[i].Type == "Stop" then break end
	end
	return points
end

function Math.CanHitTargetAfterRicochet(origin, direction, speed, targetPos, ricochetSurface, ricochetNormal, gravity)
	gravity = gravity or workspace.Gravity

	local ricochetPoint, t1 = Math.RayPlaneIntersect(origin, direction, ricochetSurface, ricochetNormal)
	if not ricochetPoint then return nil end

	local reflectDir = Math.Reflect(direction, ricochetNormal)
	local newSpeed = speed * 0.5
	local newVelocity = reflectDir * newSpeed

	local delta = targetPos - ricochetPoint
	local horizontalDist = Vector3.new(delta.X, 0, delta.Z).Magnitude
	if horizontalDist < EPSILON then return nil end

	local speedSq = newSpeed * newSpeed
	local g = gravity
	local discriminant = speedSq * speedSq - g * (g * horizontalDist * horizontalDist + 2 * delta.Y * speedSq)
	if discriminant < 0 then return nil end

	local angle = math.atan2(speedSq - math.sqrt(discriminant), g * horizontalDist)
	local launchDir = Vector3.new(delta.X, 0, delta.Z).Unit * math.cos(angle)
	launchDir = launchDir + Vector3.new(0, math.sin(angle), 0)

	if Math.AngleBetween(reflectDir, launchDir) < math.rad(30) then
		return ricochetPoint, reflectDir, newSpeed
	end

	return nil
end

function Math.RicochetKillShot(origin, direction, speed, damage, targetPos, ricochetSurface, ricochetNormal, gravity)
	local ricochetPoint, reflectDir, newSpeed = Math.CanHitTargetAfterRicochet(
		origin, direction, speed, targetPos, ricochetSurface, ricochetNormal, gravity
	)
	if not ricochetPoint then return nil end

	local distance = Math.Distance(ricochetPoint, targetPos)
	local timeToTarget = distance / newSpeed

	local newDamage = damage * 0.4

	return {
		RicochetPoint = ricochetPoint,
		ReflectDirection = reflectDir,
		Speed = newSpeed,
		Damage = newDamage,
		TimeToTarget = timeToTarget,
		TargetPosition = targetPos,
	}
end

