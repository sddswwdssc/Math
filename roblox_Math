function Math.BallisticRaycast(origin, velocity, gravity, raycastParams, timeStep, maxTime)
	gravity = gravity or workspace.Gravity
	timeStep = timeStep or 0.05
	maxTime = maxTime or 10
	local pos = origin
	local vel = velocity
	local t = 0
	local g = Vector3.new(0, -gravity, 0)
	while t < maxTime do
		local nextPos = pos + vel * timeStep + 0.5 * g * timeStep * timeStep
		local dir = nextPos - pos
		local dist = dir.Magnitude
		if dist > EPSILON then
			local result = workspace:Raycast(pos, dir.Unit * dist, raycastParams)
			if result then
				local hitDist = (result.Position - pos).Magnitude

				local hitTime = hitDist / dist * timeStep
				return result, result.Position, t + hitTime
			end
		end
		pos = nextPos
		vel = vel + g * timeStep
		t = t + timeStep
	end
	return nil
end

function Math.DamageFalloff(damage, distance, minDistance, maxDistance)
	if distance <= minDistance then return damage end
	if distance >= maxDistance then return 0 end
	local t = (distance - minDistance) / (maxDistance - minDistance)
	return damage * (1 - t)
end

function Math.ExplosionDamage(center, targetPos, maxDamage, maxRadius, minRadius)
	minRadius = minRadius or 0
	local dist = Math.Distance(center, targetPos)
	if dist > maxRadius then return 0 end
	if dist <= minRadius then return maxDamage end
	local t = (dist - minRadius) / (maxRadius - minRadius)
	return maxDamage * (1 - t)
end

local noiseState = { seed = 0, perm = {} }

local function initNoisePermutation(seed)
	local perm = {}
	for i = 0, 255 do perm[i] = i end
	local rng = RNG.new(seed)
	for i = 255, 1, -1 do
		local j = rng:NextInteger(0, i)
		perm[i], perm[j] = perm[j], perm[i]
	end
	for i = 0, 255 do perm[i + 256] = perm[i] end
	return perm
end

local function grad(hash, x, y, z)
	local h = hash % 16
	local u, v
	if h < 8 then
		u = x
	else
		u = y
	end
	if h < 4 then
		v = y
	elseif h == 12 or h == 14 then
		v = x
	else
		v = z
	end
	local uVal = (h % 2) == 0 and u or -u
	local vVal = (h % 4) < 2 and v or -v
	return uVal + vVal
end

local function fade(t) return t * t * t * (t * (t * 6 - 15) + 10) end

-- 柏林噪声，抄的wiki，能用就行
function Math.PerlinNoise3D(x, y, z, seed)
	seed = seed or noiseState.seed
	local seedKey = tostring(seed)
	if not noiseState.perm[seedKey] then
		noiseState.perm[seedKey] = initNoisePermutation(seed)
	end
	local perm = noiseState.perm[seedKey]

	local xi = math.floor(x) % 256
	local yi = math.floor(y) % 256
	local zi = math.floor(z) % 256
	local xf = x - math.floor(x)
	local yf = y - math.floor(y)
	local zf = z - math.floor(z)
	local u = fade(xf)
	local v = fade(yf)
	local w = fade(zf)

	local function p(ix, iy, iz)
		local idx1 = perm[xi + ix]
		if idx1 == nil then error("Noise permutation index out of bounds: xi=" .. tostring(xi) .. ", ix=" .. tostring(ix)) end
		local idx2 = perm[idx1 + yi + iy]
		if idx2 == nil then error("Noise permutation index out of bounds: yi=" .. tostring(yi) .. ", iy=" .. tostring(iy)) end
		local idx3 = perm[idx2 + zi + iz]
		if idx3 == nil then error("Noise permutation index out of bounds: zi=" .. tostring(zi) .. ", iz=" .. tostring(iz)) end
		return idx3
	end

	local aaa = p(0, 0, 0)
	local aba = p(0, 1, 0)
	local aab = p(0, 0, 1)
	local abb = p(0, 1, 1)
	local baa = p(1, 0, 0)
	local bba = p(1, 1, 0)
	local bab = p(1, 0, 1)
	local bbb = p(1, 1, 1)

	local x1 = Math.Lerp(grad(aaa, xf, yf, zf), grad(baa, xf - 1, yf, zf), u)
	local x2 = Math.Lerp(grad(aba, xf, yf - 1, zf), grad(bba, xf - 1, yf - 1, zf), u)
	local y1 = Math.Lerp(x1, x2, v)

	local x3 = Math.Lerp(grad(aab, xf, yf, zf - 1), grad(bab, xf - 1, yf, zf - 1), u)
	local x4 = Math.Lerp(grad(abb, xf, yf - 1, zf - 1), grad(bbb, xf - 1, yf - 1, zf - 1), u)
	local y2 = Math.Lerp(x3, x4, v)

	return (Math.Lerp(y1, y2, w) + 1) / 2
end

function Math.PerlinNoise(x, y, z, seed)
	return Math.PerlinNoise3D(x or 0, y or 0, z or 0, seed)
end

-- FIXME: 无seed时每次结果不同，不知道算不算bug
function Math.OctaveNoise(x, y, z, octaves, persistence, lacunarity, seed)
	octaves = octaves or 4
	persistence = persistence or 0.5
	lacunarity = lacunarity or 2

	if seed == nil then
		seed = math.floor(globalRNG:NextNumber() * RNG_MODULUS)
	end
	local value = 0
	local amplitude = 1
	local frequency = 1
	local maxValue = 0
	for i = 1, octaves do
		local octaveSeed = (seed ~ (i * 0x9E3779B9)) % RNG_MODULUS
		value = value + amplitude * Math.PerlinNoise3D(x * frequency, y * frequency, z * frequency, octaveSeed)
		maxValue = maxValue + amplitude
		amplitude = amplitude * persistence
		frequency = frequency * lacunarity
	end
	return value / maxValue
end

function Math.SetNoiseSeed(seed)
	noiseState.seed = seed
	local seedKey = tostring(seed)
	noiseState.perm[seedKey] = initNoisePermutation(seed)
end

