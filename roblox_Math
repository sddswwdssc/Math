local Math = {}

local EPSILON = 1e-10

local DEFAULT_MATERIAL = {}
local INF = math.huge
local PI = math.pi
local TAU = 2 * math.pi
local DEG_TO_RAD = math.pi / 180
local RAD_TO_DEG = 180 / math.pi
local RNG_MODULUS = 4294967296

Math.EPSILON = EPSILON
Math.INF = INF
Math.PI = PI
Math.TAU = TAU
Math.DEG_TO_RAD = DEG_TO_RAD
Math.RAD_TO_DEG = RAD_TO_DEG

function Math.Clamp(value, min, max)
	return math.min(math.max(value, min), max)
end

function Math.Sign(value)
	return value > 0 and 1 or value < 0 and -1 or 0
end

function Math.Approximately(a, b, epsilon)
	epsilon = epsilon or EPSILON
	return math.abs(a - b) < epsilon
end

function Math.Remap(value, fromMin, fromMax, toMin, toMax)
	return toMin + (value - fromMin) / (fromMax - fromMin) * (toMax - toMin)
end

Math.MapRange = function(...)
	if _G.__MATH_DEPRECATION_WARNINGS then
		warn("[Math] MapRange已废弃，请使用Math.Remap替代")
	end
	return Math.Remap(...)
end

function Math.Smoothstep(edge0, edge1, x)
	local t = Math.Clamp((x - edge0) / (edge1 - edge0), 0, 1)
	return t * t * (3 - 2 * t)
end

local RNG = {}
RNG.__index = RNG

function RNG.new(seed)
	local self = setmetatable({}, RNG)
	if seed == nil then

		RNG._counter = (RNG._counter or 0) + 1
		local base = math.floor(tick() * 1000000) % RNG_MODULUS
		local rand = math.floor(math.random() * 1000000)

		local counterHash = (RNG._counter * 0x9E3779B9) % RNG_MODULUS
		seed = (base ~ rand ~ counterHash) % RNG_MODULUS
	end
	self.state0 = seed
	self.state1 = (seed ~ 0xDEADBEEF) % RNG_MODULUS
	for _ = 1, 8 do
		self:NextNumber()
	end
	return self
end

function RNG:NextNumber()
	local s1 = self.state0
	local s0 = self.state1
	self.state0 = s0
	local s1_shift = s1 << 23
	s1 = s1 ~ s1_shift
	self.state1 = s1 ~ s0 ~ (s1 >> 18) ~ (s0 >> 5)
	return (self.state1 + s0) / 4503599627370496 % 1
end

function RNG:NextInteger(min, max)
	if not max then
		min, max = 1, min
	end
	return math.floor(min + self:NextNumber() * (max - min + 1))
end

function RNG:NextFloat(min, max)
	min = min or 0
	max = max or 1
	return min + self:NextNumber() * (max - min)
end

Math.RNG = RNG

local globalRNG = RNG.new()

function Math.Randomize(value, rng)
	rng = rng or globalRNG
	return (0.5 - rng:NextNumber()) * 2 * value
end

function Math.Randomize2(min, max, accuracy, rng)
	rng = rng or globalRNG
	local inverse = 1 / (accuracy or 1)
	return rng:NextInteger(min * inverse, max * inverse) / inverse
end

function Math.RandomVector3(minMag, maxMag, rng)
	rng = rng or globalRNG
	local v = Vector3.new(
		(0.5 - rng:NextNumber()) * 2,
		(0.5 - rng:NextNumber()) * 2,
		(0.5 - rng:NextNumber()) * 2
	)
	if v.Magnitude < EPSILON then return Vector3.zero end
	local mag = minMag + rng:NextNumber() * (maxMag - minMag)
	return v.Unit * mag
end

function Math.RandomPointOnSphere(radius, rng)
	rng = rng or globalRNG
	local theta = rng:NextNumber() * TAU
	local phi = math.acos(2 * rng:NextNumber() - 1)
	local r = radius or 1
	return Vector3.new(
		r * math.sin(phi) * math.cos(theta),
		r * math.sin(phi) * math.sin(theta),
		r * math.cos(phi)
	)
end

function Math.RandomPointInCircle(radius, rng)
	rng = rng or globalRNG
	local angle = rng:NextNumber() * TAU
	local r = radius * math.sqrt(rng:NextNumber())
	return Vector3.new(r * math.cos(angle), 0, r * math.sin(angle))
end

function Math.RandomPointInCone(direction, angle, rng)
	rng = rng or globalRNG
	local z = 1 - rng:NextNumber() * (1 - math.cos(angle))
	local phi = rng:NextNumber() * TAU
	local r = math.sqrt(1 - z * z)
	local localDir = Vector3.new(r * math.cos(phi), r * math.sin(phi), z)
	local cf = CFrame.new(Vector3.zero, direction)
	return (cf * CFrame.new(localDir)).LookVector
end

function Math.Normalize(v)
	local m = v.Magnitude
	if m > EPSILON then return v / m end
	return Vector3.zero
end

function Math.Dot(a, b)
	return a.X * b.X + a.Y * b.Y + a.Z * b.Z
end

function Math.Cross(a, b)
	return Vector3.new(
		a.Y * b.Z - a.Z * b.Y,
		a.Z * b.X - a.X * b.Z,
		a.X * b.Y - a.Y * b.X
	)
end

function Math.Reflect(v, normal)
	return v - 2 * Math.Dot(v, normal) * normal
end

function Math.Project(v, onto)
	local ontoUnit = Math.Normalize(onto)
	return Math.Dot(v, ontoUnit) * ontoUnit
end

function Math.ProjectOnPlane(v, planeNormal)
	return v - Math.Dot(v, planeNormal) * planeNormal
end

function Math.Distance(a, b)
	return (b - a).Magnitude
end

function Math.Direction(from, to)
	return Math.Normalize(to - from)
end

function Math.AngleBetween(a, b)
	return math.acos(Math.Clamp(Math.Dot(Math.Normalize(a), Math.Normalize(b)), -1, 1))
end

function Math.SignedAngle(from, to, axis)
	local angle = Math.AngleBetween(from, to)
	local cross = Math.Cross(from, to)
	if Math.Dot(cross, axis) < 0 then
		return -angle
	end
	return angle
end

function Math.MoveTowards(current, target, maxDelta)
	local diff = target - current
	local mag = diff.Magnitude
	if mag <= maxDelta or mag < EPSILON then
		return target
	end
	return current + diff / mag * maxDelta
end

function Math.RotateTowards(current, target, maxDegreesDelta)
	local angle = Math.AngleBetween(current, target)
	if angle < 1e-6 then return target end
	local t = math.min(maxDegreesDelta * DEG_TO_RAD / angle, 1)
	return Math.Slerp(current, target, t)
end

function Math.VectorLerp(a, b, t)
	return a + (b - a) * t
end

function Math.Slerp(a, b, t)
	local dot = Math.Dot(a, b)
	if dot < 0 then
		b = -b
		dot = -dot
	end
	if dot > 0.9995 then
		return Math.Normalize(a + (b - a) * t)
	end
	local theta0 = math.acos(dot)
	local theta = theta0 * t
	local sinTheta = math.sin(theta)
	local sinTheta0 = math.sin(theta0)
	local s0 = math.cos(theta) - dot * sinTheta / sinTheta0
	local s1 = sinTheta / sinTheta0
	return s0 * a + s1 * b
end

local function ToQuaternion(c)
	local x, y, z, xx, yx, zx, xy, yy, zy, xz, yz, zz = c:GetComponents()
	local tr = xx + yy + zz
	if tr > 2.99999 then
		return x, y, z, 0, 0, 0, 1
	elseif tr > -0.99999 then
		local m = 2 * (tr + 1) ^ 0.5
		return x, y, z, (yz - zy) / m, (zx - xz) / m, (xy - yx) / m, m / 4
	else
		local qx = xx + yx + zx + 1
		local qy = xy + yy + zy + 1
		local qz = xz + yz + zz + 1
		local m = (qx * qx + qy * qy + qz * qz) ^ 0.5
		return x, y, z, qx / m, qy / m, qz / m, 0
	end
end

function Math.ToQuaternion(c)
	return ToQuaternion(c)
end

function Math.FromAxisAngle(x, y, z)
	if not y then
		x, y, z = x.X, x.Y, x.Z
	end
	local m = (x * x + y * y + z * z) ^ 0.5
	if m > 1e-5 then
		local si = math.sin(m / 2) / m
		return CFrame.new(0, 0, 0, si * x, si * y, si * z, math.cos(m / 2))
	else
		return CFrame.new()
	end
end

function Math.EulerToCFrame(x, y, z)
	return CFrame.fromEulerAnglesXYZ(x, y, z)
end

function Math.CFrameToEuler(cf)
	return cf:ToEulerAnglesXYZ()
end

function Math.Lerp(a, b, t)
	return a + (b - a) * t
end

function Math.CFrameLerp(a, b, t)
	return a:Lerp(b, t)
end

function Math.Interpolator(c0, c1)
	if c1 then
		local x0, y0, z0, qx0, qy0, qz0, qw0 = ToQuaternion(c0)
		local x1, y1, z1, qx1, qy1, qz1, qw1 = ToQuaternion(c1)
		local x, y, z = x1 - x0, y1 - y0, z1 - z0
		local dot = qx0 * qx1 + qy0 * qy1 + qz0 * qz1 + qw0 * qw1
		if dot < 0 then
			qx0, qy0, qz0, qw0 = -qx0, -qy0, -qz0, -qw0
			dot = -dot
		end
		dot = Math.Clamp(dot, -1, 1)
		if dot > 0.9999 then
			return function(t)
				return CFrame.new(x0 + t * x, y0 + t * y, z0 + t * z, qx1, qy1, qz1, qw1)
			end
		end
		local s = math.sqrt(1 - dot * dot)
		local th = math.acos(dot)
		return function(t)
			local s0 = math.sin(th * (1 - t)) / s
			local s1 = math.sin(th * t) / s
			return CFrame.new(
				x0 + t * x, y0 + t * y, z0 + t * z,
				s0 * qx0 + s1 * qx1, s0 * qy0 + s1 * qy1,
				s0 * qz0 + s1 * qz1, s0 * qw0 + s1 * qw1
			)
		end
	else
		local x, y, z, qx, qy, qz, qw = ToQuaternion(c0)
		if math.abs(qw) > 0.9999 then
			return function(t)
				return CFrame.new(t * x, t * y, t * z, qx, qy, qz, qw)
			end
		end
		local s = math.sqrt(1 - qw * qw)
		local th = math.acos(qw)
		return function(t)
			local s1 = math.sin(th * t) / s
			return CFrame.new(
				t * x, t * y, t * z,
				s1 * qx, s1 * qy, s1 * qz,
				math.sin(th * (1 - t)) / s + s1 * qw
			)
		end
	end
end

Math.Easing = {}

function Math.Easing.Linear(t) return t end
function Math.Easing.SineIn(t) return 1 - math.cos(t * PI / 2) end
function Math.Easing.SineOut(t) return math.sin(t * PI / 2) end
function Math.Easing.SineInOut(t) return -(math.cos(PI * t) - 1) / 2 end
function Math.Easing.QuadIn(t) return t * t end
function Math.Easing.QuadOut(t) return 1 - (1 - t) ^ 2 end
function Math.Easing.QuadInOut(t) return t < 0.5 and 2 * t * t or 1 - (-2 * t + 2) ^ 2 / 2 end
function Math.Easing.CubicIn(t) return t ^ 3 end
function Math.Easing.CubicOut(t) return 1 - (1 - t) ^ 3 end
function Math.Easing.CubicInOut(t) return t < 0.5 and 4 * t ^ 3 or 1 - (-2 * t + 2) ^ 3 / 2 end
function Math.Easing.QuartIn(t) return t ^ 4 end
function Math.Easing.QuartOut(t) return 1 - (1 - t) ^ 4 end
function Math.Easing.QuartInOut(t) return t < 0.5 and 8 * t ^ 4 or 1 - (-2 * t + 2) ^ 4 / 2 end
function Math.Easing.QuintIn(t) return t ^ 5 end
function Math.Easing.QuintOut(t) return 1 - (1 - t) ^ 5 end
function Math.Easing.QuintInOut(t) return t < 0.5 and 16 * t ^ 5 or 1 - (-2 * t + 2) ^ 5 / 2 end
function Math.Easing.ExpoIn(t) return t == 0 and 0 or 2 ^ (10 * t - 10) end
function Math.Easing.ExpoOut(t) return t == 1 and 1 or 1 - 2 ^ (-10 * t) end
function Math.Easing.ExpoInOut(t)
	if t == 0 then return 0 elseif t == 1 then return 1 end
	return t < 0.5 and 2 ^ (20 * t - 10) / 2 or (2 - 2 ^ (-20 * t + 10)) / 2
end
function Math.Easing.CircIn(t) return 1 - math.sqrt(1 - t * t) end
function Math.Easing.CircOut(t) return math.sqrt(1 - (t - 1) ^ 2) end
function Math.Easing.CircInOut(t)
	return t < 0.5 and (1 - math.sqrt(1 - 4 * t * t)) / 2 or (math.sqrt(1 - (-2 * t + 2) ^ 2) + 1) / 2
end
-- 别问为什么是2.70158，我也不知道，反正能用
function Math.Easing.BackIn(t) return 2.70158 * t ^ 3 - 1.70158 * t * t end
function Math.Easing.BackOut(t) return 1 + 2.70158 * (t - 1) ^ 3 + 1.70158 * (t - 1) ^ 2 end
function Math.Easing.BackInOut(t)
	local c1 = 1.70158 * 1.525
	return t < 0.5 and ((2 * t) ^ 2 * ((c1 + 1) * 2 * t - c1)) / 2
		or ((2 * t - 2) ^ 2 * ((c1 + 1) * (2 * t - 2) + c1) + 2) / 2
end
function Math.Easing.ElasticIn(t)
	if t == 0 or t == 1 then return t end
	return -(2 ^ (10 * t - 10)) * math.sin((t * 10 - 10.75) * TAU / 3)
end
function Math.Easing.ElasticOut(t)
	if t == 0 or t == 1 then return t end
	return 2 ^ (-10 * t) * math.sin((t * 10 - 0.75) * TAU / 3) + 1
end
function Math.Easing.ElasticInOut(t)
	if t == 0 or t == 1 then return t end
	local c5 = TAU / 4.5
	if t < 0.5 then
		return -(2 ^ (20 * t - 10) * math.sin((20 * t - 11.125) * c5)) / 2
	else
		return 2 ^ (-20 * t + 10) * math.sin((20 * t - 11.125) * c5) / 2 + 1
	end
end
function Math.Easing.BounceIn(t) return 1 - Math.Easing.BounceOut(1 - t) end
function Math.Easing.BounceOut(t)
	local bounceAmplitude = 7.5625
	local bounceDivisor = 2.75
	if t < 1 / bounceDivisor then return bounceAmplitude * t * t
	elseif t < 2 / bounceDivisor then t = t - 1.5 / bounceDivisor; return bounceAmplitude * t * t + 0.75
	elseif t < 2.5 / bounceDivisor then t = t - 2.25 / bounceDivisor; return bounceAmplitude * t * t + 0.9375
	else t = t - 2.625 / bounceDivisor; return bounceAmplitude * t * t + 0.984375 end
end
function Math.Easing.BounceInOut(t)
	return t < 0.5 and (1 - Math.Easing.BounceOut(1 - 2 * t)) / 2
		or (1 + Math.Easing.BounceOut(2 * t - 1)) / 2
end

function Math.Spring(initialValue, damping, speed)

	damping = damping or 0.5
	speed = speed or 10
	local self = {
		_target = initialValue or 0,
		_position = initialValue or 0,
		_velocity = 0,
		Damping = damping,
		Speed = speed,
	}

	function self:Update(dt)
		local force = self.Speed * self.Speed * (self._target - self._position)
		local dampingForce = 2 * self.Damping * self.Speed * self._velocity
		self._velocity = self._velocity + (force - dampingForce) * dt
		self._position = self._position + self._velocity * dt
		return self._position
	end

	function self:Impulse(impulse)
		self._velocity = self._velocity + impulse
	end

	function self:GetPosition() return self._position end
	function self:GetVelocity() return self._velocity end
	function self:GetTarget() return self._target end
	function self:SetTarget(value) self._target = value end
	function self:SetPosition(value) self._position = value end
	function self:SetVelocity(value) self._velocity = value end

	return self
end

function Math.VectorSpring(initial, damping, speed)

	damping = damping or 0.5
	speed = speed or 10
	local self = {
		_target = initial or Vector3.zero,
		_position = initial or Vector3.zero,
		_velocity = Vector3.zero,
		Damping = damping,
		Speed = speed,
	}

	function self:Update(dt)
		local force = self.Speed * self.Speed * (self._target - self._position)
		local dampingForce = 2 * self.Damping * self.Speed * self._velocity
		self._velocity = self._velocity + (force - dampingForce) * dt
		self._position = self._position + self._velocity * dt
		return self._position
	end

	function self:Impulse(impulse)
		self._velocity = self._velocity + impulse
	end

	function self:GetPosition() return self._position end
	function self:GetVelocity() return self._velocity end
	function self:GetTarget() return self._target end
	function self:SetTarget(value) self._target = value end
	function self:SetPosition(value) self._position = value end
	function self:SetVelocity(value) self._velocity = value end

	return self
end

function Math.SphereVsSphere(pos1, r1, pos2, r2)
	return Math.Distance(pos1, pos2) <= r1 + r2
end

function Math.PointInBox(point, boxCenter, boxSize)
	local half = boxSize / 2
	return math.abs(point.X - boxCenter.X) <= half.X
		and math.abs(point.Y - boxCenter.Y) <= half.Y
		and math.abs(point.Z - boxCenter.Z) <= half.Z
end

function Math.RayPlaneIntersect(rayOrigin, rayDirection, planePoint, planeNormal)
	planeNormal = Math.Normalize(planeNormal)
	local denom = Math.Dot(planeNormal, rayDirection)
	if math.abs(denom) < EPSILON then return nil end
	local t = Math.Dot(planeNormal, planePoint - rayOrigin) / denom
	if t < 0 then return nil end
	return rayOrigin + rayDirection * t, t
end

function Math.RaySphereIntersect(rayOrigin, rayDirection, sphereCenter, sphereRadius)
	local oc = rayOrigin - sphereCenter
	local a = Math.Dot(rayDirection, rayDirection)
	local b = 2 * Math.Dot(oc, rayDirection)
	local c = Math.Dot(oc, oc) - sphereRadius * sphereRadius
	local discriminant = b * b - 4 * a * c
	if discriminant < 0 then return nil end
	local t = (-b - math.sqrt(discriminant)) / (2 * a)
	if t < 0 then t = (-b + math.sqrt(discriminant)) / (2 * a) end
	if t < 0 then return nil end
	return rayOrigin + rayDirection * t, t
end

function Math.ClosestPointOnSegment(point, segA, segB)
	local ab = segB - segA
	local dotAB = Math.Dot(ab, ab)
	if dotAB < EPSILON then return segA, 0 end
	local t = Math.Dot(point - segA, ab) / dotAB
	t = Math.Clamp(t, 0, 1)
	return segA + t * ab, t
end

function Math.ClosestPointOnLine(point, linePoint, lineDirection)
	lineDirection = Math.Normalize(lineDirection)
	local t = Math.Dot(point - linePoint, lineDirection)
	return linePoint + t * lineDirection, t
end

function Math.LineVsLineClosestPoints(p1, d1, p2, d2)
	d1 = Math.Normalize(d1)
	d2 = Math.Normalize(d2)
	local n = Math.Cross(d1, d2)
	local nMag = n.Magnitude
	if nMag < EPSILON then return p1, p2 end
	n = n / nMag
	local n1 = Math.Cross(d1, n)
	local n2 = Math.Cross(d2, n)
	local denom1 = Math.Dot(d1, n2)
	local denom2 = Math.Dot(d2, n1)
	if math.abs(denom1) < EPSILON or math.abs(denom2) < EPSILON then return p1, p2 end
	local c1 = p1 + Math.Dot(p2 - p1, n2) / denom1 * d1
	local c2 = p2 + Math.Dot(p1 - p2, n1) / denom2 * d2
	return c1, c2
end

function Math.ProjectilePosition(origin, velocity, acceleration, time)
	return origin + velocity * time + 0.5 * acceleration * time * time
end

function Math.ProjectileVelocity(velocity, acceleration, time)
	return velocity + acceleration * time
end

function Math.PredictPosition(targetPos, targetVelocity, projectileSpeed, origin)
	local offset = targetPos - origin
	local a = targetVelocity:Dot(targetVelocity) - projectileSpeed * projectileSpeed
	local b = 2 * targetVelocity:Dot(offset)
	local c = offset:Dot(offset)
	if math.abs(a) < EPSILON then
		if math.abs(b) < EPSILON then
			if c < EPSILON then
				return targetPos, 0
			end
			return nil
		end
		local t = -c / b
		if t < 0 then return nil end
		return targetPos + targetVelocity * t, t
	end
	local discriminant = b * b - 4 * a * c
	if discriminant < 0 then return nil end
	local t = (-b - math.sqrt(discriminant)) / (2 * a)
	if t < 0 then t = (-b + math.sqrt(discriminant)) / (2 * a) end
	if t < 0 then return nil end
	return targetPos + targetVelocity * t, t
end

function Math.PredictPositionWithAccel(targetPos, targetVelocity, targetAccel, projectileSpeed, origin)
	local t = Math.Distance(origin, targetPos) / projectileSpeed
	for _ = 1, 20 do
		local predictedPos = targetPos + targetVelocity * t + 0.5 * targetAccel * t * t
		local newT = Math.Distance(origin, predictedPos) / projectileSpeed
		if math.abs(newT - t) < 0.001 then return predictedPos, newT end
		t = newT
	end
	return nil
end

function Math.InterceptTime(targetPos, targetVelocity, projectileSpeed, origin)
	return select(2, Math.PredictPosition(targetPos, targetVelocity, projectileSpeed, origin))
end

function Math.MovingTargetIntercept(origin, projectileSpeed, targetPos, targetVelocity, targetAccel)
	local t = Math.Distance(origin, targetPos) / projectileSpeed
	for _ = 1, 20 do
		local predictedPos = targetPos + targetVelocity * t + 0.5 * targetAccel * t * t
		local newT = Math.Distance(origin, predictedPos) / projectileSpeed
		if math.abs(newT - t) < 0.001 then
			return predictedPos, newT, (predictedPos - origin).Unit * projectileSpeed
		end
		t = newT
	end
	return nil
end

function Math.BallisticAngle(origin, target, speed, gravity)
	gravity = gravity or workspace.Gravity
	local delta = target - origin
	local horizontalDist = Vector3.new(delta.X, 0, delta.Z).Magnitude
	if horizontalDist < EPSILON then return nil end
	local heightDiff = delta.Y
	local speedSq = speed * speed
	local g = gravity
	local discriminant = speedSq * speedSq - g * (g * horizontalDist * horizontalDist + 2 * heightDiff * speedSq)
	if discriminant < 0 then return nil end
	local angle1 = math.atan2(speedSq - math.sqrt(discriminant), g * horizontalDist)
	local angle2 = math.atan2(speedSq + math.sqrt(discriminant), g * horizontalDist)
	return angle1, angle2
end

function Math.BallisticVelocity(origin, target, speed, gravity, useHighArc)
	gravity = gravity or workspace.Gravity
	local delta = target - origin
	local horizontalDist = Vector3.new(delta.X, 0, delta.Z).Magnitude
	if horizontalDist < EPSILON then return Vector3.new(0, speed, 0) end
	local angle1, angle2 = Math.BallisticAngle(origin, target, speed, gravity)
	local angle = useHighArc and angle2 or angle1
	if not angle then return nil end
	local horizontalDir = Vector3.new(delta.X, 0, delta.Z).Unit
	return horizontalDir * math.cos(angle) * speed + Vector3.new(0, math.sin(angle) * speed, 0)
end

function Math.BallisticTimeOfFlight(velocity, gravity)
	gravity = gravity or workspace.Gravity
	if gravity < EPSILON then return INF end
	return 2 * velocity.Y / gravity
end

function Math.BallisticMaxHeight(origin, velocity, gravity)
	gravity = gravity or workspace.Gravity
	if gravity < EPSILON then return INF end
	return origin.Y + (velocity.Y * velocity.Y) / (2 * gravity)
end

function Math.BallisticRange(velocity, gravity, heightDiff)
	gravity = gravity or workspace.Gravity
	if gravity < EPSILON then return INF end
	heightDiff = heightDiff or 0
	local v = velocity.Magnitude
	if v < EPSILON then return 0 end
	local vy = velocity.Y
	local ratio = vy / v

	if ratio > 1 or ratio < -1 then
		return nil, {code = "INVALID_INPUT", message = "velocity.Y exceeds speed magnitude"}
	end
	local angle = math.asin(ratio)
	local cosAngle = math.cos(angle)
	local sinAngle = math.sin(angle)
	return (v * cosAngle / gravity) * (v * sinAngle + math.sqrt(v * v * sinAngle * sinAngle + 2 * gravity * heightDiff))
end

function Math.LobBallisticVelocity(origin, target, time, gravity)
	gravity = gravity or Vector3.new(0, -workspace.Gravity, 0)
	local displacement = target - origin
	if time < EPSILON then return nil end
	return (displacement - 0.5 * gravity * time * time) / time
end

function Math.BallisticTrajectory(origin, velocity, gravity, timeStep, maxTime)
	gravity = gravity or workspace.Gravity
	timeStep = timeStep or 0.1
	maxTime = maxTime or 10
	local points = {}
	local pos = origin
	local vel = velocity
	local t = 0
	local g = Vector3.new(0, -gravity, 0)
	while t < maxTime do
		table.insert(points, pos)

		vel = vel + g * timeStep
		pos = pos + vel * timeStep
		t = t + timeStep
		if pos.Y < -1000 then break end
	end
	return points
end

-- print("SimulateProjectile called") -- debug
function Math.SimulateProjectile(origin, velocity, gravity, wind, drag, timeStep, maxTime)
	gravity = gravity or workspace.Gravity
	wind = wind or Vector3.zero
	drag = drag or 0
	timeStep = timeStep or 0.05
	maxTime = maxTime or 20
	local pos = origin
	local vel = velocity
	local t = 0
	local g = Vector3.new(0, -gravity, 0)
	local stopped = false

	local function iterator()
		if stopped or t >= maxTime or pos.Y < -1000 then return nil end
		local result = { Position = pos, Velocity = vel, Time = t }
		local acceleration = g + wind - drag * vel
		vel = vel + acceleration * timeStep
		pos = pos + vel * timeStep
		t = t + timeStep
		return result
	end
	local function stop()
		local wasRunning = not stopped and t < maxTime and pos.Y >= -1000
		stopped = true
		return wasRunning
	end
	return iterator, stop
end

